generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Bug {
  id        Int      @id @default(autoincrement())
  title     String
  severity  String
  status    String   @default("open")
  assignee  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}